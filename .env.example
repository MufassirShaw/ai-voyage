# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6   # optional, this is the default
ANTHROPIC_MAX_TOKENS=1024           # optional, this is the default

# OpenAI (embeddings)
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small   # optional, this is the default

# Database URI

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres